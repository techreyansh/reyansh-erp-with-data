# Environment Variables Example
# Copy this file to .env.local and fill in your actual values
# The .env.local file is already in .gitignore and will not be committed to version control

# Supabase (required for this app) — from https://supabase.com/dashboard → your project → Settings → API
# URL format: https://<project-ref>.supabase.co  (use your live project ref; old shared refs may NXDOMAIN)
#
# This repo uses Create React App: you MUST use the REACT_APP_ prefix (not VITE_).
# After editing .env or .env.local, restart: npm start
# Your project URL (example from team setup):
# REACT_APP_SUPABASE_URL=https://azwdxgahmdgccfimhtmm.supabase.co
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=
# Optional (new Supabase API keys): used if ANON_KEY is empty
# REACT_APP_SUPABASE_PUBLISHABLE_KEY=
#
# If you migrate to Vite, use instead (and remove REACT_APP_ lines):
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# WhatsApp Link
# Replace with your actual WhatsApp link (e.g., https://wa.me/1234567890)
REACT_APP_WHATSAPP_LINK=https://wa.me/

# Other environment variables can be added here
# Local document-only mode: `useLocalStorage` in src/config/config.js is forced false; Supabase table
# calls in src/lib/db.js do not skip the API. Do not rely on REACT_APP_USE_LOCAL_STORAGE for data.
